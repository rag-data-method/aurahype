# Build local do frontend: em produção o CDK injeta a URL da API automaticamente.
VITE_API_URL=

# OPCIONAIS — quando você quiser ligar dados reais do Instagram.
# Sem estes, a app roda em modo demonstração com fotos placeholder.
META_ACCESS_TOKEN_SECRET_ARN=
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=
META_GRAPH_API_VERSION=v22.0
