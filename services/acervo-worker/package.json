{
  "name": "@site-forge/acervo-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Triade 56 acervo worker: ingest scraped sites, embed with Workers AI, index in Vectorize, classify with LLM.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:init": "wrangler d1 execute triade-acervo --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute triade-acervo --remote --file=./schema.sql",
    "vectorize:create": "wrangler vectorize create triade-acervo --dimensions=1024 --metric=cosine"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.8.3",
    "wrangler": "^3.99.0"
  }
}
